#!/bin/bash
choice=`/usr/bin/echo -e "LEFT/RIGHT\nLEFT/(right)\n(left)/RIGHT" | dmenu`

case "$choice" in
   'LEFT/RIGHT')  /usr/bin/displaylr.sh & ;;
   'LEFT/(right)') /usr/bin/displayl.sh & ;;
   '(left)/RIGHT') /usr/bin/displayr.sh & ;;
   *) exit ;;
esac

